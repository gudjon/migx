#!/usr/bin/env python3
"""Offline judges for NextGen module fixtures.

The first judge target is mod-music-management-mode. It validates the fixture
contract that the QML ARRANGE mode will consume before any live UI/network work
is allowed into the club path.
"""
from __future__ import annotations

import argparse
import json
import re
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any


REPO = Path(__file__).resolve().parents[1]
DEFAULT_FIXTURE = REPO / "fixtures/music-mode-50"
DEFAULT_DECK_CLOCK_FIXTURE = REPO / "fixtures/deck-clock-states.json"
DEFAULT_DECK_IDENTITY_FIXTURE = REPO / "fixtures/deck-identity-states.json"
NEXTGEN_QML = REPO / "res/qml/nextgen"
KEYMAP = REPO / "res/design/KEYMAP.md"
DECK_CLOCK_QML = REPO / "res/qml/nextgen/components/DeckClock.qml"
DECK_CLOCK_MODEL_QML = REPO / "res/qml/nextgen/components/DeckClockModel.qml"
DECK_IDENTITY_QML = REPO / "res/qml/nextgen/components/DeckIdentity.qml"
DECK_IDENTITY_MODEL_QML = REPO / "res/qml/nextgen/components/DeckIdentityModel.qml"
KEYS_PROTO = REPO / "src/proto/keys.proto"
KEYUTILS_CPP = REPO / "src/track/keyutils.cpp"
ALLOWED_CHIP_KINDS = {
    "youtube_views",
    "beatport_chart",
    "soundcloud_plays",
    "local_plays",
    "setlist_appearances",
}
FORBIDDEN_V1_CHIP_KINDS = {"mixcloud_sets"}
HEX_LITERAL_RE = re.compile(r"(?<![\w])['\"]?#[0-9A-Fa-f]{3,8}['\"]?")
COLOR_CONSTRUCTOR_RE = re.compile(r"\bQt\.(?:rgba|hsla?|darker|lighter|tint)\s*\(")
COLOR_STRING_RE = re.compile(
    r"\b(?:color|border\.color|property\s+color\s+\w+)\s*:\s*['\"][^'\"]+['\"]"
)
VISUAL_NUMERIC_RE = re.compile(
    r"\b(?:"
    r"width|height|spacing|padding|leftPadding|rightPadding|topPadding|bottomPadding|"
    r"font\.pixelSize|duration|opacity|radius|border\.width|anchors\.margins|"
    r"anchors\.leftMargin|anchors\.rightMargin|anchors\.topMargin|anchors\.bottomMargin"
    r")\s*:\s*-?\d+(?:\.\d+)?\b"
)
BLOCKING_COMPONENT_RE = re.compile(
    r"^\s*(?:Dialog|MessageDialog|FileDialog|FolderDialog|ColorDialog|FontDialog)\s*\{"
)
MODAL_TRUE_RE = re.compile(r"\bmodal\s*:\s*true\b")
SHORTCUT_RE = re.compile(
    r"\bsequences?\s*:\s*(\[[^\]]*\]|\"[^\"]+\"|'[^']+')"
)
STRING_LITERAL_RE = re.compile(r"\"([^\"]+)\"|'([^']+)'")


class JudgeError(Exception):
    pass


@dataclass(frozen=True)
class MusicFixture:
    root: Path
    tracks: dict[str, dict[str, Any]]
    tags: dict[str, dict[str, Any]]
    playlists: dict[str, dict[str, Any]]
    track_tags: dict[str, list[str]]
    playlist_tracks: dict[str, list[str]]
    track_playlists: dict[str, list[str]]
    community: dict[str, dict[str, Any]]
    history: dict[str, int]
    deck_state: dict[str, Any]
    layout: dict[str, Any]
    transitions: dict[str, Any]


def read_jsonl(path: Path) -> list[dict[str, Any]]:
    if not path.is_file():
        raise JudgeError(f"missing fixture file: {path}")
    rows: list[dict[str, Any]] = []
    for line_no, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        if not raw.strip():
            continue
        try:
            rows.append(json.loads(raw))
        except json.JSONDecodeError as exc:
            raise JudgeError(f"{path}:{line_no}: {exc}") from exc
    return rows


def read_json(path: Path) -> dict[str, Any]:
    if not path.is_file():
        raise JudgeError(f"missing fixture file: {path}")
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise JudgeError(f"{path}: {exc}") from exc


def load_fixture(root: Path) -> MusicFixture:
    root = root.resolve()
    tracks = {row["id"]: row for row in read_jsonl(root / "library.jsonl")}
    tags = {row["id"]: row for row in read_jsonl(root / "tags.jsonl")}
    playlists = {row["id"]: row for row in read_jsonl(root / "playlists.jsonl")}

    track_tags: dict[str, list[str]] = {track_id: [] for track_id in tracks}
    for row in read_jsonl(root / "track_tags.jsonl"):
        track_tags.setdefault(row["track_id"], []).append(row["tag_id"])

    playlist_tracks: dict[str, list[str]] = {playlist_id: [] for playlist_id in playlists}
    track_playlists: dict[str, list[str]] = {track_id: [] for track_id in tracks}
    for row in read_jsonl(root / "playlist_tracks.jsonl"):
        playlist_tracks.setdefault(row["playlist_id"], []).append(row["track_id"])
        track_playlists.setdefault(row["track_id"], []).append(row["playlist_id"])

    community: dict[str, dict[str, Any]] = {}
    community_path = root / "community_signal/index.jsonl"
    for row in read_jsonl(community_path):
        community[row["track_id"]] = row

    history = {
        row["track_id"]: int(row.get("local_plays", 0))
        for row in read_jsonl(root / "history.jsonl")
    }

    transitions_path = root / "transitions.json"
    transitions = read_json(transitions_path) if transitions_path.is_file() else {}

    return MusicFixture(
        root=root,
        tracks=tracks,
        tags=tags,
        playlists=playlists,
        track_tags=track_tags,
        playlist_tracks=playlist_tracks,
        track_playlists=track_playlists,
        community=community,
        history=history,
        deck_state=read_json(root / "free_decks.json"),
        layout=read_json(root / "layout.json"),
        transitions=transitions,
    )


def assert_fixture_integrity(fx: MusicFixture) -> None:
    if len(fx.tracks) < 50:
        raise JudgeError(f"expected >=50 tracks, got {len(fx.tracks)}")
    if len(fx.tags) < 8:
        raise JudgeError(f"expected >=8 tags, got {len(fx.tags)}")
    if len(fx.playlists) < 4:
        raise JudgeError(f"expected >=4 playlists, got {len(fx.playlists)}")

    for track_id, track in fx.tracks.items():
        for field in ("title", "artist", "bpm", "key", "energy", "art_stub", "waveform_thumb"):
            if track.get(field) in (None, ""):
                raise JudgeError(f"{track_id}: missing {field}")
        if track_id not in fx.track_tags or not fx.track_tags[track_id]:
            raise JudgeError(f"{track_id}: missing tag relation")
        if track_id not in fx.track_playlists or not fx.track_playlists[track_id]:
            raise JudgeError(f"{track_id}: missing playlist relation")

    for track_id, tag_ids in fx.track_tags.items():
        if track_id not in fx.tracks:
            raise JudgeError(f"track_tags: unknown track {track_id}")
        for tag_id in tag_ids:
            if tag_id not in fx.tags:
                raise JudgeError(f"track_tags: unknown tag {tag_id}")

    for playlist_id, track_ids in fx.playlist_tracks.items():
        if playlist_id not in fx.playlists:
            raise JudgeError(f"playlist_tracks: unknown playlist {playlist_id}")
        for track_id in track_ids:
            if track_id not in fx.tracks:
                raise JudgeError(f"playlist_tracks: unknown track {track_id}")

    for track_id, signal in fx.community.items():
        if track_id not in fx.tracks:
            raise JudgeError(f"community_signal: unknown track {track_id}")
        for chip in signal.get("chips", []):
            kind = chip.get("kind")
            if kind in FORBIDDEN_V1_CHIP_KINDS:
                raise JudgeError(f"{track_id}: forbidden v1 chip kind {kind}")
            if kind not in ALLOWED_CHIP_KINDS:
                raise JudgeError(f"{track_id}: unknown chip kind {kind}")
            if float(chip.get("match_confidence", 0.0)) < 0.7:
                raise JudgeError(f"{track_id}: chip {kind} below confidence gate")

    coverage = len(fx.community) / len(fx.tracks)
    if coverage < 0.60:
        raise JudgeError(f"community signal coverage {coverage:.2%} below 60%")

    # Optional ARRANGE co-occurrence priors (migx.transition_priors.v1)
    if fx.transitions:
        schema = fx.transitions.get("schema", "")
        if schema != "migx.transition_priors.v1":
            raise JudgeError(f"transitions.json: expected schema migx.transition_priors.v1, got {schema!r}")
        edges = fx.transitions.get("edges")
        if not isinstance(edges, list) or len(edges) < 1:
            raise JudgeError("transitions.json: edges must be a non-empty list")
        for i, edge in enumerate(edges):
            for field in ("from", "to", "count"):
                if field not in edge:
                    raise JudgeError(f"transitions.json edges[{i}]: missing {field}")
            if edge["from"] not in fx.tracks:
                raise JudgeError(f"transitions.json: unknown from track {edge['from']}")
            if edge["to"] not in fx.tracks:
                raise JudgeError(f"transitions.json: unknown to track {edge['to']}")
            if int(edge["count"]) < 1:
                raise JudgeError(f"transitions.json edges[{i}]: count must be >= 1")


def track_search_text(fx: MusicFixture, track_id: str) -> str:
    track = fx.tracks[track_id]
    tag_names = [fx.tags[tag_id]["name"] for tag_id in fx.track_tags.get(track_id, [])]
    return " ".join([
        str(track.get("title", "")),
        str(track.get("artist", "")),
        str(track.get("remixer", "")),
        *tag_names,
    ]).lower()


def key_compatible(candidate: str, target: str) -> bool:
    def parse(key: str) -> tuple[int, str]:
        if len(key) < 2:
            raise JudgeError(f"invalid Camelot key {key!r}")
        return int(key[:-1]), key[-1].upper()

    c_num, c_letter = parse(candidate)
    t_num, t_letter = parse(target)
    adjacent = {((t_num - 2) % 12) + 1, t_num, (t_num % 12) + 1}
    return (c_letter == t_letter and c_num in adjacent) or (c_num == t_num and c_letter != t_letter)


def cmd_fixture_load(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    print(
        f"OK fixture-load tracks={len(fx.tracks)} tags={len(fx.tags)} "
        f"playlists={len(fx.playlists)} chips={len(fx.community)} "
        f"transition_edges={len(fx.transitions.get('edges') or [])}"
    )


def cmd_search(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    query = args.q.lower()
    ids = sorted(track_id for track_id in fx.tracks if query in track_search_text(fx, track_id))
    if args.expect_ids:
        expected = [item.strip() for item in args.expect_ids.split(",") if item.strip()]
        if ids != expected:
            raise JudgeError(f"search ids {ids} != expected {expected}")
    print(f"OK search q={args.q!r} ids={','.join(ids)}")


def cmd_filter(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    target = fx.deck_state.get("free_deck_key")
    if not target:
        raise JudgeError("free_decks.json missing free_deck_key")
    ids = sorted(track_id for track_id, track in fx.tracks.items() if key_compatible(track["key"], target))
    if args.expect_count_range:
        low_raw, high_raw = args.expect_count_range.split(",", 1)
        low, high = int(low_raw), int(high_raw)
        if not low <= len(ids) <= high:
            raise JudgeError(f"compatible count {len(ids)} not in range {low},{high}")
    print(f"OK filter key_target={target} count={len(ids)}")


def require_card_fields(args: argparse.Namespace, fx: MusicFixture) -> None:
    requirements = {item.strip() for item in (args.require or "").split(",") if item.strip()}
    if "chips" in requirements and not args.track:
        coverage = len(fx.community) / len(fx.tracks)
        if coverage < 0.60:
            raise JudgeError(f"community chip coverage {coverage:.2%} below 60%")
        requirements.remove("chips")
    track_ids = [args.track] if args.track else sorted(fx.tracks)
    for track_id in track_ids:
        if track_id not in fx.tracks:
            raise JudgeError(f"unknown track {track_id}")
        track = fx.tracks[track_id]
        checks = {
            "art": bool(track.get("art_stub")),
            "bpm": track.get("bpm") is not None,
            "key": bool(track.get("key")),
            "energy": track.get("energy") is not None,
            "tags": bool(fx.track_tags.get(track_id)),
            "playlists": bool(fx.track_playlists.get(track_id)),
            "chips": track_id in fx.community,
        }
        for requirement in requirements:
            if requirement == "chips" and args.assert_chip_empty_ok:
                continue
            if requirement not in checks:
                raise JudgeError(f"unknown card requirement {requirement}")
            if not checks[requirement]:
                raise JudgeError(f"{track_id}: card requirement failed: {requirement}")


def cmd_cards(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    require_card_fields(args, fx)
    if args.assert_no_modal and fx.layout.get("modal") is not False:
        raise JudgeError("layout modal flag is not false")
    print("OK cards")


def cmd_switch_roundtrip(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    if args.assert_playhead_continues:
        if not fx.deck_state.get("playhead_continues_on_mode_switch"):
            raise JudgeError("playhead_continues_on_mode_switch is not true")
        playing = [d for d in fx.deck_state.get("decks", []) if d.get("is_playing")]
        if not playing:
            raise JudgeError("no playing deck in fixture")
    threshold = int(fx.deck_state.get("mode_switch_ms_p95", 9999))
    if threshold > 100:
        raise JudgeError(f"mode switch p95 {threshold}ms exceeds 100ms")
    print(f"OK switch-roundtrip p95={threshold}ms")


def choose_deck(args: argparse.Namespace, fx: MusicFixture) -> dict[str, Any]:
    decks = fx.deck_state.get("decks", [])
    if args.deck == "free":
        for deck in decks:
            if deck.get("status") == "free":
                return deck
        raise JudgeError("no free deck available")
    if args.deck == "busy":
        for deck in decks:
            if deck.get("status") != "free":
                return deck
        raise JudgeError("no busy deck available")
    for deck in decks:
        if deck.get("id") == args.deck:
            return deck
    raise JudgeError(f"unknown deck selector {args.deck}")


def cmd_stage_and_load(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    if args.track not in fx.tracks:
        raise JudgeError(f"unknown track {args.track}")
    if args.require_ack is not True:
        raise JudgeError("stage-and-load requires explicit ack")
    deck = choose_deck(args, fx)
    if deck.get("status") != "free":
        raise JudgeError(f"selected deck {deck.get('id')} is not free")
    print(f"OK stage-and-load track={args.track} deck={deck.get('id')}")


def cmd_load(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    deck = choose_deck(args, fx)
    rejected = deck.get("status") != "free"
    if args.expect_reject and not rejected:
        raise JudgeError(f"expected reject but selected deck {deck.get('id')} is free")
    if not args.expect_reject and rejected:
        raise JudgeError(f"deck {deck.get('id')} is busy; load rejected")
    print(f"OK load track={args.track} deck={deck.get('id')} rejected={str(rejected).lower()}")


def cmd_offline_box(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    if args.deny_net and fx.layout.get("network_hot_path") is not False:
        raise JudgeError("network_hot_path flag is not false")
    aliases = {
        "fixture-load": lambda: cmd_fixture_load(args, fx),
        "search-stable": lambda: cmd_search(
            argparse.Namespace(q="peak", expect_ids="id:03,id:11,id:27"), fx
        ),
        "cards-render": lambda: cmd_cards(
            argparse.Namespace(
                require="art,bpm,key,energy,tags,playlists,chips",
                track=None,
                assert_no_modal=False,
                assert_chip_empty_ok=False,
            ),
            fx,
        ),
    }
    for item in [part.strip() for part in args.run.split(",") if part.strip()]:
        if item not in aliases:
            raise JudgeError(f"unknown offline-box run alias {item}")
        aliases[item]()
    print("OK offline-box")


def cmd_screenshot(args: argparse.Namespace, fx: MusicFixture) -> None:
    assert_fixture_integrity(fx)
    sizes = [part.strip() for part in args.sizes.split(",") if part.strip()]
    layout_sizes = fx.layout.get("sizes", {})
    for size in sizes:
        if size not in layout_sizes:
            raise JudgeError(f"layout missing size {size}")
        if args.assert_no_text_overlap and layout_sizes[size].get("text_overlap") is not False:
            raise JudgeError(f"{size}: text_overlap is not false")
    print(f"OK screenshot sizes={','.join(sizes)}")


def format_clock(sec: float, has_track: bool) -> str:
    if not has_track or sec < 0:
        return "--:--"
    whole = int(sec)
    minutes = whole // 60
    remainder = whole % 60
    return f"{minutes}:{remainder:02d}"


def derive_deck_clock_state(row: dict[str, Any], threshold_sec: int) -> dict[str, Any]:
    has_track = float(row.get("track_loaded", 0)) > 0
    duration = float(row.get("duration", 0))
    position = min(1.0, max(0.0, float(row.get("playposition", 0))))
    elapsed_sec = position * duration
    remaining_sec = max(0.0, duration - elapsed_sec)
    ending = has_track and remaining_sec > 0 and remaining_sec <= threshold_sec
    return {
        "elapsed": format_clock(elapsed_sec, has_track),
        "remaining": "-" + format_clock(remaining_sec, has_track) if has_track else format_clock(0, False),
        "total": format_clock(duration, has_track),
        "ending": ending,
        "remaining_color": "Theme.red" if ending else ("Theme.textColor" if has_track else "Theme.midGray"),
        "context_color": "Theme.midGray",
    }


def assert_deck_clock_qml_contract() -> None:
    clock_text = DECK_CLOCK_QML.read_text(encoding="utf-8")
    model_text = DECK_CLOCK_MODEL_QML.read_text(encoding="utf-8")
    required_clock_fragments = [
        "text: view.remaining",
        "view.ending ? Theme.red",
        "view.hasTrack ? Theme.textColor : Theme.midGray",
        "text: view.elapsed",
        "text: view.total",
    ]
    required_model_fragments = [
        'key: "duration"',
        'key: "playposition"',
        'key: "track_loaded"',
        "endingThresholdSec: 30",
        'remaining: hasTrack ? "-" + format(remainingSec) : format(0)',
    ]
    for fragment in required_clock_fragments:
        if fragment not in clock_text:
            raise JudgeError(f"{rel(DECK_CLOCK_QML)} missing contract fragment: {fragment}")
    for fragment in required_model_fragments:
        if fragment not in model_text:
            raise JudgeError(f"{rel(DECK_CLOCK_MODEL_QML)} missing contract fragment: {fragment}")


def cmd_deck_clock_states(args: argparse.Namespace) -> None:
    fixture_path = Path(args.fixture)
    if not fixture_path.is_absolute():
        fixture_path = REPO / fixture_path
    fixture = read_json(fixture_path)
    threshold_sec = int(fixture.get("threshold_sec", 30))
    expected_ids = {"no-track", "playing", "ending"}
    rows = fixture.get("states", [])
    ids = {row.get("id") for row in rows}
    missing = expected_ids - ids
    if missing:
        raise JudgeError(f"{rel(fixture_path)} missing DeckClock states: {sorted(missing)}")
    assert_deck_clock_qml_contract()
    for row in rows:
        derived = derive_deck_clock_state(row, threshold_sec)
        expected = row.get("expect", {})
        for key, want in expected.items():
            got = derived.get(key)
            if got != want:
                raise JudgeError(
                    f"{row.get('id')}: {key}={got!r}, expected {want!r}"
                )
    print(f"OK deck clock-states states={len(rows)}")


def strip_line_comment(line: str) -> str:
    in_single = False
    in_double = False
    index = 0
    while index < len(line) - 1:
        char = line[index]
        prev = line[index - 1] if index > 0 else ""
        if char == "'" and not in_double and prev != "\\":
            in_single = not in_single
        elif char == '"' and not in_single and prev != "\\":
            in_double = not in_double
        elif char == "/" and line[index + 1] == "/" and not in_single and not in_double:
            return line[:index]
        index += 1
    return line


def strip_js_line_comments(text: str) -> str:
    return "\n".join(strip_line_comment(line) for line in text.splitlines())


def parse_chromatic_key_ids() -> dict[int, str]:
    text = KEYS_PROTO.read_text(encoding="utf-8")
    match = re.search(r"enum\s+ChromaticKey\s*\{(?P<body>.*?)\};", text, re.DOTALL)
    if not match:
        raise JudgeError(f"{rel(KEYS_PROTO)} missing enum ChromaticKey")
    ids: dict[int, str] = {}
    for item in re.finditer(r"^\s*([A-Z_]+)\s*=\s*(\d+)\s*;", match.group("body"), re.MULTILINE):
        ids[int(item.group(2))] = item.group(1)
    for key_id in range(0, 25):
        if key_id not in ids:
            raise JudgeError(f"{rel(KEYS_PROTO)} missing ChromaticKey id {key_id}")
    return ids


def parse_keyutils_open_key_map() -> dict[str, int]:
    text = KEYUTILS_CPP.read_text(encoding="utf-8")
    entries = re.findall(
        r"\{\s*mixxx::track::io::key::([A-Z_]+),\s*"
        r"mixxx::track::io::key::([A-Z_]+)\s*\},?\s*//\s*(\d+)",
        text,
    )
    if len(entries) != 12:
        raise JudgeError(f"{rel(KEYUTILS_CPP)} expected 12 s_openKeyToKeys entries, got {len(entries)}")
    key_to_open: dict[str, int] = {}
    for major_key, minor_key, open_key_raw in entries:
        open_key = int(open_key_raw)
        key_to_open[major_key] = open_key
        key_to_open[minor_key] = open_key
    return key_to_open


def open_key_to_lancelot_number(open_key_number: int) -> int:
    lancelot_number = open_key_number - 5
    return lancelot_number + 12 if lancelot_number < 1 else lancelot_number


def parse_deck_identity_camelot_table() -> dict[int, int]:
    text = strip_js_line_comments(DECK_IDENTITY_MODEL_QML.read_text(encoding="utf-8"))
    match = re.search(r"var\s+t\s*=\s*\[(?P<body>.*?)\]\s*;", text, re.DOTALL)
    if not match:
        raise JudgeError(f"{rel(DECK_IDENTITY_MODEL_QML)} missing camelotNumber() table")
    values = [int(raw) for raw in re.findall(r"-?\d+", match.group("body"))]
    if len(values) != 25:
        raise JudgeError(f"{rel(DECK_IDENTITY_MODEL_QML)} camelot table expected 25 values, got {len(values)}")
    return {key_id: values[key_id] for key_id in range(0, 25)}


def parse_deck_identity_names() -> dict[int, str]:
    text = strip_js_line_comments(DECK_IDENTITY_MODEL_QML.read_text(encoding="utf-8"))
    match = re.search(r"var\s+names\s*=\s*\[(?P<body>.*?)\]\s*;", text, re.DOTALL)
    if not match:
        raise JudgeError(f"{rel(DECK_IDENTITY_MODEL_QML)} missing keyLabel() names table")
    names = [
        quoted.group(1) if quoted.group(1) is not None else quoted.group(2)
        for quoted in re.finditer(r"\"([^\"]*)\"|'([^']*)'", match.group("body"))
    ]
    if len(names) != 25:
        raise JudgeError(f"{rel(DECK_IDENTITY_MODEL_QML)} key names table expected 25 values, got {len(names)}")
    return {key_id: names[key_id] for key_id in range(0, 25)}


def expected_deck_identity_keymap() -> dict[int, dict[str, Any]]:
    key_ids = parse_chromatic_key_ids()
    key_to_open = parse_keyutils_open_key_map()
    qml_names = parse_deck_identity_names()
    expected: dict[int, dict[str, Any]] = {}
    for key_id in range(1, 25):
        key_name = key_ids[key_id]
        if key_name not in key_to_open:
            raise JudgeError(f"{rel(KEYUTILS_CPP)} missing OpenKey mapping for {key_name}")
        number = open_key_to_lancelot_number(key_to_open[key_name])
        letter = "B" if key_id <= 12 else "A"
        label = f"{qml_names[key_id]} · {number}{letter}"
        expected[key_id] = {
            "key_name": key_name,
            "camelot_number": number,
            "camelot_label": f"{number}{letter}",
            "label": label,
        }
    return expected


def derive_deck_identity_state(row: dict[str, Any], expected_keymap: dict[int, dict[str, Any]]) -> dict[str, Any]:
    has_track = float(row.get("track_loaded", 0)) > 0
    title = str(row.get("title", ""))
    artist = str(row.get("artist", ""))
    art_url = str(row.get("art_url", ""))
    bpm = float(row.get("bpm", 0))
    key_id = int(round(float(row.get("key", 0))))
    key_entry = expected_keymap.get(key_id)
    bpm_text = f"{bpm:.1f}" if has_track and bpm > 0 else "--"
    key_text = key_entry["label"] if has_track and key_entry else "--"
    key_camelot = int(key_entry["camelot_number"]) if has_track and key_entry else 0
    title_text = title if has_track and title else ("Untitled" if has_track else "— no track —")
    return {
        "has_track": has_track,
        "title_text": title_text,
        "artist_text": artist,
        "artist_visible": has_track and artist != "",
        "art_source": art_url if has_track else "",
        "bpm_text": bpm_text,
        "bpm_badge": f"{bpm_text} BPM",
        "key_text": key_text,
        "key_badge": key_text,
        "key_camelot": key_camelot,
        "key_color": f"Theme.keyWheel{key_camelot}" if key_camelot > 0 else "Theme.transparent",
        "title_elides": has_track and len(title) >= int(row.get("long_title_min_chars", 10_000)),
    }


def assert_deck_identity_qml_contract() -> None:
    view_text = DECK_IDENTITY_QML.read_text(encoding="utf-8")
    model_text = DECK_IDENTITY_MODEL_QML.read_text(encoding="utf-8")
    required_view_fragments = [
        "text: view.hasTrack ? (view.title !== \"\" ? view.title : \"Untitled\") : \"— no track —\"",
        "elide: Text.ElideRight",
        "Layout.maximumWidth: Theme.nextgenWindowWidth / 3",
        "source: view.hasTrack ? view.artUrl : \"\"",
        "text: view.bpmText + \" BPM\"",
        "text: view.keyText",
        "accent: view.keyColor",
        "Theme[\"keyWheel\" + keyCamelot]",
    ]
    required_model_fragments = [
        "READ-ONLY",
        "DeckIdentityModel",
        'key: "track_loaded"',
        'key: "bpm"',
        'key: "key"',
        "function camelotNumber(k)",
        "function keyLabel(k)",
    ]
    for fragment in required_view_fragments:
        if fragment not in view_text:
            raise JudgeError(f"{rel(DECK_IDENTITY_QML)} missing contract fragment: {fragment}")
    for fragment in required_model_fragments:
        if fragment not in model_text:
            raise JudgeError(f"{rel(DECK_IDENTITY_MODEL_QML)} missing contract fragment: {fragment}")
    forbidden_writes = re.findall(r"\b(?:loadedControl|bpmControl|keyControl)\.value\s*=", model_text)
    if forbidden_writes:
        raise JudgeError(f"{rel(DECK_IDENTITY_MODEL_QML)} writes to ControlProxy value: {forbidden_writes}")


def cmd_deck_identity_states(args: argparse.Namespace) -> None:
    fixture_path = Path(args.fixture)
    if not fixture_path.is_absolute():
        fixture_path = REPO / fixture_path
    fixture = read_json(fixture_path)
    expected_ids = {"no-track", "loaded", "long-title"}
    rows = fixture.get("states", [])
    ids = {row.get("id") for row in rows}
    missing = expected_ids - ids
    if missing:
        raise JudgeError(f"{rel(fixture_path)} missing DeckIdentity states: {sorted(missing)}")

    assert_deck_identity_qml_contract()
    expected_keymap = expected_deck_identity_keymap()
    qml_camelot = parse_deck_identity_camelot_table()
    fixture_keymap = {int(row["key_id"]): row for row in fixture.get("keymap", [])}
    if set(fixture_keymap) != set(range(1, 25)):
        raise JudgeError(f"{rel(fixture_path)} keymap must contain key_id 1..24")
    for key_id, expected in expected_keymap.items():
        got_number = qml_camelot.get(key_id)
        if got_number != expected["camelot_number"]:
            raise JudgeError(
                f"key_id {key_id}: DeckIdentityModel camelotNumber={got_number!r}, "
                f"expected {expected['camelot_number']!r} from KeyUtils Lancelot"
            )
        fixture_expected = fixture_keymap[key_id]
        for field in ("key_name", "camelot_number", "camelot_label", "label"):
            if fixture_expected.get(field) != expected[field]:
                raise JudgeError(
                    f"key_id {key_id}: fixture {field}={fixture_expected.get(field)!r}, "
                    f"expected {expected[field]!r}"
                )

    for row in rows:
        derived = derive_deck_identity_state(row, expected_keymap)
        expected = row.get("expect", {})
        for key, want in expected.items():
            got = derived.get(key)
            if got != want:
                raise JudgeError(f"{row.get('id')}: {key}={got!r}, expected {want!r}")
    print(f"OK deck identity-states states={len(rows)} keymap=24 read_only=true")


def iter_qml_files(root: Path) -> list[Path]:
    root = root.resolve()
    if not root.exists():
        raise JudgeError(f"QML path does not exist: {root}")
    if root.is_file():
        if root.suffix != ".qml":
            raise JudgeError(f"QML path is not a .qml file: {root}")
        return [root]
    return sorted(path for path in root.rglob("*.qml") if path.is_file())


def rel(path: Path) -> str:
    try:
        return str(path.relative_to(REPO))
    except ValueError:
        return str(path)


def normalize_shortcut(sequence: str) -> str:
    aliases = {
        "ctrl": "⌘",
        "control": "⌘",
        "cmd": "⌘",
        "command": "⌘",
        "meta": "⌘",
        "shift": "⇧",
        "alt": "⌥",
        "option": "⌥",
        "left": "←",
        "right": "→",
        "up": "↑",
        "down": "↓",
        "escape": "Esc",
        "return": "Enter",
    }
    pieces = [part.strip() for part in sequence.split("+") if part.strip()]
    return "".join(aliases.get(part.lower(), part) for part in pieces)


def collect_qml_shortcuts(path: Path, code: str) -> list[tuple[str, str]]:
    shortcuts: list[tuple[str, str]] = []
    for match in SHORTCUT_RE.finditer(code):
        for literal in STRING_LITERAL_RE.finditer(match.group(1)):
            sequence = literal.group(1) or literal.group(2)
            shortcuts.append((sequence, normalize_shortcut(sequence)))
    return shortcuts


def cmd_nextgen_ui_lint(args: argparse.Namespace) -> None:
    if not args.assert_token_only and not args.assert_no_blocking_modal and not args.assert_keymap:
        args.assert_token_only = True
        args.assert_no_blocking_modal = True
        args.assert_keymap = True

    root = Path(args.path)
    if not root.is_absolute():
        root = REPO / root
    keymap_path = Path(args.keymap)
    if not keymap_path.is_absolute():
        keymap_path = REPO / keymap_path

    files = iter_qml_files(root)
    violations: list[str] = []
    keymap_text = ""
    declared_shortcuts: list[tuple[Path, int, str, str]] = []
    if args.assert_keymap:
        if not keymap_path.is_file():
            raise JudgeError(f"missing keymap SSoT: {keymap_path}")
        keymap_text = keymap_path.read_text(encoding="utf-8")

    for path in files:
        for line_no, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
            code = strip_line_comment(raw)
            if not code.strip():
                continue
            if args.assert_keymap:
                for sequence, display in collect_qml_shortcuts(path, code):
                    declared_shortcuts.append((path, line_no, sequence, display))
                    if display not in keymap_text:
                        violations.append(
                            f"{rel(path)}:{line_no}: shortcut {sequence!r} "
                            f"normalizes to {display!r}, missing from {rel(keymap_path)}"
                        )
            if args.assert_token_only:
                if HEX_LITERAL_RE.search(code):
                    violations.append(f"{rel(path)}:{line_no}: hardcoded hex/color literal")
                if COLOR_STRING_RE.search(code):
                    violations.append(f"{rel(path)}:{line_no}: hardcoded color string")
                if COLOR_CONSTRUCTOR_RE.search(code):
                    violations.append(f"{rel(path)}:{line_no}: hardcoded color constructor")
                if VISUAL_NUMERIC_RE.search(code):
                    violations.append(f"{rel(path)}:{line_no}: hardcoded visual numeric literal")
            if args.assert_no_blocking_modal:
                if BLOCKING_COMPONENT_RE.search(code):
                    violations.append(f"{rel(path)}:{line_no}: blocking dialog component")
                if MODAL_TRUE_RE.search(code):
                    violations.append(f"{rel(path)}:{line_no}: modal true")

    seen_shortcuts: dict[str, tuple[Path, int, str]] = {}
    for path, line_no, sequence, display in declared_shortcuts:
        if display in seen_shortcuts:
            first_path, first_line_no, first_sequence = seen_shortcuts[display]
            violations.append(
                f"{rel(path)}:{line_no}: duplicate QML shortcut {sequence!r} "
                f"also declared as {first_sequence!r} at {rel(first_path)}:{first_line_no}"
            )
        else:
            seen_shortcuts[display] = (path, line_no, sequence)

    if violations:
        raise JudgeError("\n  - " + "\n  - ".join(violations))
    suffix = f" shortcuts={len(declared_shortcuts)}" if args.assert_keymap else ""
    print(f"OK nextgen-ui lint files={len(files)}{suffix}")


def extract_fixture_arg(argv: list[str]) -> tuple[list[str], str]:
    """Allow --fixture before or after the action subcommand."""
    fixture = str(DEFAULT_FIXTURE)
    remaining: list[str] = []
    index = 0
    while index < len(argv):
        token = argv[index]
        if token == "--fixture":
            if index + 1 >= len(argv):
                raise JudgeError("--fixture requires a path")
            fixture = argv[index + 1]
            index += 2
            continue
        if token.startswith("--fixture="):
            fixture = token.split("=", 1)[1]
            index += 1
            continue
        remaining.append(token)
        index += 1
    return remaining, fixture


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="tools/ng-judge")
    sub = parser.add_subparsers(dest="domain", required=True)

    deck = sub.add_parser("deck")
    deck_sub = deck.add_subparsers(dest="action", required=True)
    clock = deck_sub.add_parser("clock-states")
    clock.add_argument("--fixture", default=str(DEFAULT_DECK_CLOCK_FIXTURE), help="DeckClock fixture")
    identity = deck_sub.add_parser("identity-states")
    identity.add_argument("--fixture", default=str(DEFAULT_DECK_IDENTITY_FIXTURE), help="DeckIdentity fixture")

    nextgen = sub.add_parser("nextgen-ui")
    nextgen_sub = nextgen.add_subparsers(dest="action", required=True)
    lint = nextgen_sub.add_parser("lint")
    lint.add_argument("--path", default=str(NEXTGEN_QML), help="QML file or directory")
    lint.add_argument("--assert-token-only", action="store_true")
    lint.add_argument("--assert-no-blocking-modal", action="store_true")
    lint.add_argument("--assert-keymap", action="store_true")
    lint.add_argument("--keymap", default=str(KEYMAP), help="KEYMAP.md path")

    music = sub.add_parser("music-mode")
    music_sub = music.add_subparsers(dest="action", required=True)

    music_sub.add_parser("fixture-load")

    search = music_sub.add_parser("search")
    search.add_argument("--q", required=True)
    search.add_argument("--expect-ids")

    filt = music_sub.add_parser("filter")
    filt.add_argument("--key-compat", choices=["free-deck"], required=True)
    filt.add_argument("--expect-count-range")

    cards = music_sub.add_parser("cards")
    cards.add_argument("--require", default="")
    cards.add_argument("--track")
    cards.add_argument("--assert-no-modal", action="store_true")
    cards.add_argument("--assert-chip-empty-ok", action="store_true")

    switch = music_sub.add_parser("switch-roundtrip")
    switch.add_argument("--assert-playhead-continues", action="store_true")

    stage = music_sub.add_parser("stage-and-load")
    stage.add_argument("--track", required=True)
    stage.add_argument("--deck", required=True)
    stage.add_argument("--require-ack", action="store_true")

    load = music_sub.add_parser("load")
    load.add_argument("--track", required=True)
    load.add_argument("--deck", required=True)
    load.add_argument("--expect-reject", action="store_true")

    offline = music_sub.add_parser("offline-box")
    offline.add_argument("--deny-net", action="store_true")
    offline.add_argument("--run", required=True)

    screenshot = music_sub.add_parser("screenshot")
    screenshot.add_argument("--sizes", required=True)
    screenshot.add_argument("--assert-no-text-overlap", action="store_true")

    return parser


def main(argv: list[str]) -> int:
    parser = build_parser()
    try:
        argv, fixture_arg = extract_fixture_arg(argv)
        args = parser.parse_args(argv)
        if args.domain == "nextgen-ui" and args.action == "lint":
            cmd_nextgen_ui_lint(args)
            return 0
        if args.domain == "deck" and args.action == "clock-states":
            cmd_deck_clock_states(args)
            return 0
        if args.domain == "deck" and args.action == "identity-states":
            cmd_deck_identity_states(args)
            return 0

        fx = load_fixture(Path(fixture_arg))
        if args.domain == "music-mode" and args.action == "fixture-load":
            cmd_fixture_load(args, fx)
        elif args.domain == "music-mode" and args.action == "search":
            cmd_search(args, fx)
        elif args.domain == "music-mode" and args.action == "filter":
            cmd_filter(args, fx)
        elif args.domain == "music-mode" and args.action == "cards":
            cmd_cards(args, fx)
        elif args.domain == "music-mode" and args.action == "switch-roundtrip":
            cmd_switch_roundtrip(args, fx)
        elif args.domain == "music-mode" and args.action == "stage-and-load":
            cmd_stage_and_load(args, fx)
        elif args.domain == "music-mode" and args.action == "load":
            cmd_load(args, fx)
        elif args.domain == "music-mode" and args.action == "offline-box":
            cmd_offline_box(args, fx)
        elif args.domain == "music-mode" and args.action == "screenshot":
            cmd_screenshot(args, fx)
        else:
            raise JudgeError(f"unsupported command {args.domain} {args.action}")
    except JudgeError as exc:
        print(f"FAIL: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
